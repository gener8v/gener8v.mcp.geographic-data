{
  "name": "@gener8v/mcp-geographic-data",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/gener8v/gener8v.mcp.geographic-data"
  },
  "description": "MCP server for the loc8n Geographic Data API — query demographics, housing, mortgage, migration, and employment data from any MCP-compatible client",
  "type": "module",
  "bin": {
    "mcp-geographic-data": "./dist/bin/mcp-server.js"
  },
  "main": "./dist/src/server.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/mcp-server.js",
    "lint": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "geographic-data",
    "demographics",
    "census",
    "loc8n"
  ],
  "author": "GENER8V",
  "license": "MIT",
  "mcpName": "io.github.gener8v-thomas/mcp-geographic-data",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.2.1",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.2",
    "jest": "^30.0.4",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  }
}
